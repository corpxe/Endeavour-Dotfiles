[colors]
background = #cc111827
foreground = #e5e9f0
blue = #7aa2f7
cyan = #7dcfff
pink = #bb9af7
gray = #5c6370

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

[bar/left]
monitor = HDMI-0

width = 100%
height = 32

background = ${colors.background}
foreground = ${colors.foreground}

padding-left = 3
padding-right = 3

module-margin = 2

font-0 = "JetBrainsMono Nerd Font:size=11;2"

modules-left = i3
modules-center = xwindow date
modules-right = cpu memory

wm-restack = i3
override-redirect = false

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

[bar/right]
monitor = DP-2

width = 100%
height = 32

background = ${colors.background}
foreground = ${colors.foreground}

padding-left = 3
padding-right = 3

module-margin = 2

font-0 = "JetBrainsMono Nerd Font:size=11;2"

modules-left = i3 xwindow
modules-center = prev playpause next music
modules-right = pulseaudio wlan battery

tray-position = right

wm-restack = i3
override-redirect = false

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

[module/i3]
type = internal/i3

pin-workspaces = true
enable-click = true
enable-scroll = true

ws-icon-0 = 1;
ws-icon-1 = 2;
ws-icon-2 = 3;
ws-icon-3 = 4;
ws-icon-4 = 5;

format = <label-state>

label-focused = %icon%
label-focused-foreground = ${colors.blue}
label-focused-padding = 2

label-unfocused = %icon%
label-unfocused-foreground = ${colors.gray}
label-unfocused-padding = 2

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

[module/xwindow]
type = internal/xwindow

label = %title:0:50:...%
label-foreground = ${colors.cyan}

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

[module/date]
type = internal/date

interval = 1

date = %I:%M %p
date-alt = %A, %d %B

label = 󰥔 %date%
label-foreground = ${colors.pink}

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

[module/cpu]
type = internal/cpu
interval = 2

format = <label>
label = CPU %percentage%%
label-foreground = ${colors.blue}

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

[module/memory]
type = internal/memory
interval = 2

format = <label>
label = RAM %percentage_used%%
label-foreground = ${colors.pink}

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

[module/wlan]
type = internal/network

interface = wlan0
interval = 3

format-connected = <label-connected>
format-disconnected = <label-disconnected>

label-connected = WIFI
label-disconnected = OFFLINE

label-connected-foreground = ${colors.cyan}
label-disconnected-foreground = ${colors.gray}

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

[module/battery]
type = internal/battery

battery = BAT0
adapter = ACAD

poll-interval = 5

format-discharging = <label-discharging>
format-charging = <label-charging>

label-discharging = BAT %percentage%%
label-charging = CHR %percentage%%

label-discharging-foreground = ${colors.cyan}
label-charging-foreground = ${colors.blue}

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

[module/pulseaudio]
type = internal/pulseaudio

format-volume = <label-volume>
label-volume = VOL %percentage%%

label-muted = MUTED
label-volume-foreground = ${colors.blue}

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

[module/prev]
type = custom/text

format = "󰒮"

click-left = playerctl previous

format-foreground = ${colors.blue}

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

[module/playpause]
type = custom/text

format = "󰐊"

click-left = playerctl play-pause

format-foreground = ${colors.pink}

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

[module/next]
type = custom/text

format = "󰒭"

click-left = playerctl next

format-foreground = ${colors.blue}

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

[module/music]
type = custom/script

exec = playerctl metadata --format "{{artist}} - {{title}}" 2>/dev/null
interval = 2

label-maxlen = 35
label-foreground = ${colors.cyan}
