fig.jupyter.notebookRunGroups.runIconsInExecute && config.jupyter.notebookRunGroups.enabled"},{"command":"vscode-notebook-groups.executeGroup2","when":"config.jupyter.notebookRunGroups.groupCount > 1 && notebookCellResource in notebookRunGroups.groupTwoCells && config.jupyter.notebookRunGroups.runIconsInExecute && config.jupyter.notebookRunGroups.enabled"},{"command":"vscode-notebook-groups.executeGroup3","when":"config.jupyter.notebookRunGroups.groupCount > 2 && notebookCellResource in notebookRunGroups.groupThreeCells && config.jupyter.notebookRunGroups.runIconsInExecute && config.jupyter.notebookRunGroups.enabled"}],"view/title":[{"command":"jupyter-kernelManager.refreshKernels","group":"navigation","when":"view == jupyterKernelsView"}],"view/item/context":[{"command":"jupyter-kernelManager.createnewinteractive","when":"viewItem =~ /kernelSpec:/ || viewItem =~ /remote:activeKernel:/","group":"inline"},{"command":"jupyter-kernelManager.createnewnotebook","when":"viewItem =~ /kernelSpec:/ || viewItem =~ /remote:activeKernel:/","group":"inline"},{"command":"jupyter-kernelManager.shutdownKernel","when":"view == jupyterKernelsView && viewItem =~ /activeKernel:/","group":"inline"},{"command":"jupyter-kernelManager.interruptKernel","when":"view == jupyterKernelsView && viewItem =~ /activeKernel:/","group":"inline"},{"command":"jupyter-kernelManager.restartKernel","when":"view == jupyterKernelsView && viewItem =~ /activeKernel:/","group":"inline"},{"command":"jupyter-kernelManager.editKernelSpec","when":"view == jupyterKernelsView && viewItem =~ /:startUsingLocalKernelSpec/","group":"inline"},{"command":"jupyter-kernelManager.kernelMessageCopy","when":"config.jupyter.inspectKernelMessages.enabled && view == jupyterKernelsView && viewItem =~ /kernelMessage/ && viewItem =~ /canCopyToClipboard/","group":"inline"},{"command":"jupyter-kernelManager.inspectKernelMessages","when":"config.jupyter.inspectKernelMessages.enabled && view == jupyterKernelsView && viewItem =~ /activeKernelRoot/","group":"inline"},{"command":"jupyter-kernelManager.viewKernelMessagesAsList","when":"config.jupyter.inspectKernelMessages.enabled && view == jupyterKernelsView && viewItem =~ /kernelMessagesRoot/","group":"inline@1"},{"command":"jupyter-kernelManager.viewKernelMessagesAsTree","when":"config.jupyter.inspectKernelMessages.enabled && view == jupyterKernelsView && viewItem =~ /kernelMessagesRoot/","group":"inline@2"},{"command":"jupyter-kernelManager.clearKernelMessages","when":"config.jupyter.inspectKernelMessages.enabled && view == jupyterKernelsView && viewItem =~ /kernelMessagesRoot/","group":"inline@3"}]},"views":{"jupyter":[{"type":"tree","id":"jupyterKernelsView","name":"Kernels","when":"!jupyter.hasKernels && config.jupyter.kernelManagement.enabled"},{"type":"webview","id":"jupyterContextualHelp","name":"Contextual Help","when":"config.jupyter.contextualHelp.enabled"}]},"configuration":[{"type":"object","properties":{"jupyter.notebookRunGroups.enabled":{"type":"boolean","default":true,"description":"Enable the notebook run groups feature to provide commands to run groups of notebook cells.","scope":"machine"},"jupyter.notebookRunGroups.groupCount":{"type":"integer","enum":[0,1,2,3],"default":2,"description":"Count of run groups to show (0-3).","scope":"machine"},"jupyter.notebookRunGroups.runIconsOnCell":{"type":"boolean","default":false,"description":"Display group run icons on each cell toolbar.","scope":"machine"},"jupyter.notebookRunGroups.runIconsOnEditorToolbar":{"type":"boolean","default":true,"description":"Display group run icons on the global notebook editor toolbar.","scope":"machine"},"jupyter.notebookRunGroups.runIconsInExecute":{"type":"boolean","default":true,"description":"Display group run icons in the cell execute dropdown.","scope":"machine"},"jupyter.kernelManagement.enabled":{"type":"boolean","default":true,"description":"Enable the Kernel Management feature providing ability to start/stop/interrupt kernels.","scope":"machine"},