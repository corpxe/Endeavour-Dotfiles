{
    "python.analysis.semanticTokens": false,
    "editor.semanticHighlighting.enabled": false,
    "editor.semanticTokenColorCustomizations": false,
    "workbench.statusBar.visible": false,
    "workbench.activityBar.location": "top",
    "workbench.sideBar.location": "right",
    "window.menuBarVisibility": "compact",
    "window.commandCenter": false,
    "workbench.colorTheme": "Community Material Theme Ocean High Contrast",
    "workbench.iconTheme": "material-icon-theme",
    "editor.fontFamily": "JetBrainsMono Nerd Font",
    "terminal.integrated.fontFamily": "JetBrainsMono Nerd Font",
    "editor.fontLigatures": true,
    "editor.fontSize": 15,
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.smoothScrolling": true,
    "editor.minimap.enabled": false,
    "editor.wordWrap": "on",
    "editor.formatOnSave": true,
    "files.autoSave": "afterDelay",
    "breadcrumbs.enabled": true,
    "editor.inlineSuggest.enabled": true,
    "editor.guides.bracketPairs": true,
    "editor.renderWhitespace": "selection",
    "editor.tabSize": 4,
    "editor.rulers": [
        120
    ],
    "terminal.integrated.defaultProfile.linux": "zsh",
    "python.analysis.typeCheckingMode": "basic",
    "python.defaultInterpreterPath": ".venv/bin/python",
    "jupyter.askForKernelRestart": false,
    "editor.tokenColorCustomizations": {
        "[Community Material Theme Ocean High Contrast]": {
            "textMateRules": [
                {
                    "scope": "comment",
                    "settings": {
                        "foreground": "#4FD6BE",
                        "fontStyle": "italic"
                    }
                },
                {
                    "scope": [
                        "variable",
                        "variable.other",
                        "variable.parameter",
                        "meta.definition.variable",
                        "meta.indexed-name.python",
                        "meta.item-access.python",
                        "meta.mapping.python"
                    ],
                    "settings": {
                        "foreground": "#FFB86C"
                    }
                },
                {
                    "scope": [
                        "keyword"
                    ],
                    "settings": {
                        "foreground": "#C792EA"
                    }
                },
                {
                    "scope": [
                        "entity.name.function"
                    ],
                    "settings": {
                        "foreground": "#82AAFF"
                    }
                },
                {
                    "scope": [
                        "string"
                    ],
                    "settings": {
                        "foreground": "#C3E88D"
                    }
                }
            ]
        }
    },
    "explorer.confirmDelete": false,
    "terminal.integrated.profiles.linux": {
        "bash": {
            "path": "bash",
            "icon": "terminal-bash"
        },
        "zsh": {
            "path": "/usr/bin/zsh"
        },
        "fish": {
            "path": "fish"
        },
        "tmux": {
            "path": "tmux",
            "icon": "terminal-tmux"
        },
        "pwsh": {
            "path": "pwsh",
            "icon": "terminal-powershell"
        }
    }
}